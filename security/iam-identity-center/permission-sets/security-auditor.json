{
  "Name": "SecurityAuditor",
  "Description": "Security and compliance audit access",
  "SessionDuration": "PT4H",
  "ManagedPolicies": [
    "arn:aws:iam::aws:policy/SecurityAudit",
    "arn:aws:iam::aws:policy/job-function/ViewOnlyAccess"
  ],
  "InlinePolicy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "SecurityHubRead",
        "Effect": "Allow",
        "Action": [
          "securityhub:Get*",
          "securityhub:List*",
          "securityhub:Describe*",
          "guardduty:Get*",
          "guardduty:List*",
          "macie2:Get*",
          "macie2:List*",
          "inspector2:Get*",
          "inspector2:List*"
        ],
        "Resource": "*"
      }
    ]
  }
}
